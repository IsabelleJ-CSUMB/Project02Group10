<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BudgetingActivity">

    <TextView
        android:id="@+id/budgetingHeaderTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:text="Budgeting"
        android:textSize="40sp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/budgetGoalEditText"
        android:layout_width="345dp"
        android:layout_height="42dp"
        android:layout_marginTop="16dp"
        android:hint="Enter Monthly Budget"
        android:inputType="numberDecimal"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/budgetingHeaderTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/setBudgetButton"
        android:layout_width="250dp"
        android:layout_height="100dp"
        android:layout_marginTop="4dp"
        android:text="Set Budget"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/budgetGoalEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ProgressBar
        android:id="@+id/budgetProgressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="345dp"
        android:layout_height="24dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0"
        app:layout_constraintTop_toBottomOf="@id/setBudgetButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/budgetStatusTextView"
        android:layout_width="345dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Set a budget to get started."
        android:textSize="16sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/budgetProgressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <EditText
        android:id="@+id/billNameEditText"
        android:layout_width="345dp"
        android:layout_height="42dp"
        android:layout_marginTop="16dp"
        android:hint="Enter recurring Bill Name"
        android:inputType="textAutoComplete"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/budgetStatusTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <EditText
        android:id="@+id/billAmountEditText"
        android:layout_width="345dp"
        android:layout_height="42dp"
        android:layout_marginTop="4dp"
        android:hint="Enter recurring Bill Amount"
        android:inputType="numberDecimal"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/billNameEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <Button
        android:id="@+id/addBillButton"
        android:layout_width="250dp"
        android:layout_height="100dp"
        android:layout_marginTop="4dp"
        android:text="Add recurring Bill"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/billAmountEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/billsListTextView"
        android:layout_width="345dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textSize="16sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/addBillButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:layout_width="250dp"
        android:layout_height="100dp"
        app:layout_constraintTop_toBottomOf="@id/addBillButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Back"
        android:textSize="24sp"
        android:layout_marginTop="4dp"
        android:id="@+id/budgetingViewBackButton"/>

</androidx.constraintlayout.widget.ConstraintLayout>